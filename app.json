{
  "expo": {
    "name": "Dumb Charades",
    "slug": "dumcharads",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dumcharads",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.sankalesh.dumcharads",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a103c"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}
